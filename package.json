{
  "name": "auth-passport-challenge",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "dev:js": "nodemon",
    "dev": "concurrently npm:dev:*",
    "db:create:dev": "createdbjs ${DATABASE_DB:-auth_passport_challenge_dev} --user=${DATABASE_USER:-postgres} --password=${DATABASE_PASSWORD:-postgres} --host=${DATABASE_HOST:-127.0.0.1}",
    "db:drop:dev": "dropdbjs ${DATABASE_DB:-auth_passport_challenge_dev} --user=${DATABASE_USER:-postgres} --password=${DATABASE_PASSWORD:-postgres} --host=${DATABASE_HOST:-127.0.0.1}",
    "db": "node --loader ts-node/esm ./node_modules/.bin/knex",
    "db:migrate:dev": "npm run db migrate:latest",
    "db:rollback:dev": "npm run db migrate:rollback",
    "db:make:dev": "npm run db migrate:make",
    "test": "node --loader ts-node/esm ./node_modules/.bin/vitest",
    "test:db:create": "createdbjs ${TEST_DATABASE_DB:-auth_passport_challenge_test} --user=${TEST_DATABASE_USER:-postgres} --password=${TEST_DATABASE_PASSWORD:-postgres} --host=${TEST_DATABASE_HOST:-127.0.0.1}",
    "test:db:drop": "dropdbjs ${TEST_DATABASE_DB:-auth_passport_challenge_test} --user=${TEST_DATABASE_USER:-postgres} --password=${TEST_DATABASE_PASSWORD:-postgres} --host=${TEST_DATABASE_HOST:-127.0.0.1}",
    "test:db:migrate": "NODE_ENV=test npm run db migrate:latest",
    "test:db:rollback": "NODE_ENV=test npm run db migrate:rollback"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@faker-js/faker": "^9.6.0",
    "@tsconfig/node-lts": "^20.1.3",
    "@types/ejs": "^3.1.5",
    "@types/knex-cleaner": "^1.3.6",
    "@types/node": "^20.14.8",
    "fishery": "^2.2.3",
    "knex-cleaner": "^1.3.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/session": "^11.1.0",
    "@fastify/view": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^5.1.1",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "fastify": "^5.2.2",
    "fastify-plugin": "^5.0.1",
    "knex": "^3.1.0",
    "objection": "^3.1.5",
    "pg": "^8.14.1",
    "pgtools": "^1.0.1",
    "zod": "^3.24.2"
  }
}
